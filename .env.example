# ====================================
# SCFI — Variables de entorno (ejemplo)
# Copiar como .env y completar valores
# ====================================

# ── Base de datos PostgreSQL ──────────────────────────────
# Local:
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/scfi_db"
# Railway (usar el valor que Railway entrega en el panel):
# DATABASE_URL="postgresql://USER:PASS@containers-us-west-XXX.railway.app:PORT/railway"

# ── Autenticación JWT ─────────────────────────────────────
JWT_SECRET="CAMBIA_ESTE_SECRETO_POR_UNO_LARGO_Y_ALEATORIO"
JWT_EXPIRES_IN="30d"

# ── Servidor ──────────────────────────────────────────────
PORT=5600
NODE_ENV=development     # development | production | test

# ── Edición y modo de empresa ─────────────────────────────
SCFI_EDITION=full        # full | lite  (lite = máx 100 comprobantes/año)
MODO_EMPRESA=mono        # mono | multi (multi = multi-empresa)

# ── CORS / Frontend URL ───────────────────────────────────
FRONTEND_URL=http://localhost:5174
# En producción (Vercel):
# FRONTEND_URL=https://scfi.vercel.app

# ── SMTP para notificaciones por correo (opcional) ────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false        # true para puerto 465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SCFI <no-reply@tudominio.com>"

# ── SRI Ecuador (endpoints XML) ──────────────────────────
# Los valores por defecto están en backend/config/sri.js
# Solo sobreescribir si el SRI cambia sus URLs:
# SRI_RECEPCION_URL=https://cel.sri.gob.ec/comprobantes-electronicos-ws/RecepcionComprobantesOffline?wsdl
# SRI_AUTORIZACION_URL=https://cel.sri.gob.ec/comprobantes-electronicos-ws/AutorizacionComprobantesOffline?wsdl

# ── Uploads / Archivos temporales ─────────────────────────
UPLOAD_MAX_MB=10

# Railway (reemplazar con tus valores del panel de Railway → Postgres → Connect):
# DATABASE_URL="postgresql://postgres:PASSWORD@switchyard.proxy.rlwy.net:PORT/railway"