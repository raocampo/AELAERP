{
  "name": "aela-backend",
  "version": "1.0.0",
  "description": "Backend AELA — ERP de Comprobantes Fiscales (Ecuador SRI)",
  "main": "server.js",
  "scripts": {
    "start": "npx prisma migrate deploy && node server.js",
    "dev": "nodemon server.js",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "prisma:migrate": "npm run db:migrate:dev:safe --",
    "prisma:generate": "npx prisma generate",
    "prisma:studio": "npx prisma studio",
    "prisma:push": "echo \"Usa npm run db:migrate:safe o npm run db:migrate:dev:safe -- --name nombre\" && exit 1",
    "db:backup": "node scripts/dbMaintenance.js backup",
    "db:restore": "node scripts/dbMaintenance.js restore",
    "db:migrate:safe": "node scripts/dbMaintenance.js migrate",
    "db:migrate:dev:safe": "node scripts/dbMaintenance.js migrate-dev",
    "catastro:check": "node scripts/importarCatastroSRI.js --dry-run",
    "catastro:import": "node scripts/importarCatastroSRI.js",
    "catastro:replace": "node scripts/dbMaintenance.js backup && node scripts/importarCatastroSRI.js --replace"
  },
  "keywords": [
    "sri",
    "facturacion",
    "ecuador",
    "prisma",
    "nodejs"
  ],
  "author": "CorpSimtelec",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^2.4.3",
    "bwip-js": "^4.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "fast-xml-parser": "^5.5.9",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.3.5",
    "multer": "^2.0.2",
    "node-forge": "^1.3.3",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2",
    "puppeteer": "^24.42.0",
    "qrcode": "^1.5.4",
    "xlsx": "^0.18.5",
    "xml-crypto": "^6.1.2",
    "xmlbuilder2": "^4.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "prisma": "^5.22.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
