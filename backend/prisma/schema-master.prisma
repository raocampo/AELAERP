// ====================================
// PRISMA SCHEMA — BD MASTER (catálogo de tenants)
// BD: aela_master
// Genera: @prisma/client-master
// ====================================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client-master"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_MASTER_URL")
}

// ── Tenants (una fila = una empresa cliente) ──────────────────────────────────
model tenants {
  id               Int       @id @default(autoincrement())
  slug             String    @unique @db.VarChar(50)  // subdominio: empresa → empresa.aela.ec
  plan             String    @default("lite") @db.VarChar(10)  // lite | medium | pro
  estado           String    @default("provisioning") @db.VarChar(20)
  // estado: provisioning | activo | suspendido | vencido | error

  // Datos de conexión a la BD del tenant
  dbName           String    @db.VarChar(80)
  dbHost           String    @default("localhost") @db.VarChar(100)
  dbPort           Int       @default(5432)
  dbUser           String    @default("postgres") @db.VarChar(50)
  dbPass           String    @db.VarChar(200)

  // Datos del contacto
  emailContacto    String?   @db.VarChar(150)
  telefonoContacto String?   @db.VarChar(30)
  nombreContacto   String?   @db.VarChar(200)

  // Suscripción
  periodoFacturacion String?  @db.VarChar(10)  // mensual | anual
  fechaActivacion   DateTime?
  fechaVencimiento  DateTime?
  autoRenovar       Boolean  @default(false)
  esTrial           Boolean  @default(false)
  trialExpiresAt    DateTime?

  // Tipo de instancia — solo aplica cuando plan = 'pro'
  tipoInstancia    String?   @default("monoempresa") @db.VarChar(20)
  // monoempresa → máx 1 empresa | multiempresa → N empresas ilimitadas

  // Módulos contratados — techo explícito por tenant, independiente del plan.
  // null = sin restricción explícita, se usa el techo legado derivado de `plan`
  // (capacidadesModulos() en backend/utils/configuracionSistema.js).
  // Array de claves de configuracion_sistema, ej: ["contabilidadHabilitada","atsHabilitado"]
  modulosContratados Json?

  // Branding (white-label)
  brandConfig      Json?    // { dominio, logo, apiKey, ... }

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  suscripciones    suscripciones[]
  solicitudesPago  solicitudes_pago[]
}

// ── Historial de suscripciones y pagos ───────────────────────────────────────
model suscripciones {
  id             Int      @id @default(autoincrement())
  tenantId       Int
  plan           String   @db.VarChar(10)
  periodo        String?  @db.VarChar(10)   // mensual | anual
  monto          Decimal? @db.Decimal(10,2)
  estado         String   @default("activo") @db.VarChar(20)
  fechaInicio    DateTime @default(now())
  fechaFin       DateTime?
  pagoReferencia String?  @db.VarChar(200)
  proveedor      String?  @db.VarChar(50)   // stripe | paypal | payphone | manual

  tenant         tenants  @relation(fields: [tenantId], references: [id])
  createdAt      DateTime @default(now())
}

// ── Solicitudes de pago (checkout) ───────────────────────────────────────────
model solicitudes_pago {
  id              Int      @id @default(autoincrement())
  tenantId        Int
  plan            String   @db.VarChar(20)   // lite | medium | pro
  periodo         String   @db.VarChar(20)   // mensual | anual
  monto           Decimal  @db.Decimal(10,2)
  proveedor       String   @db.VarChar(30)   // transferencia | payphone | stripe | paypal
  estado          String   @default("pendiente") @db.VarChar(20)
  // pendiente | pagado | rechazado | expirado | revision
  referencia      String?  @db.VarChar(300)  // comprobante transferencia o txId externo
  checkoutUrl     String?  @db.VarChar(500)  // URL de PayPhone/Stripe
  transactionId   String?  @db.VarChar(200)  // ID en el proveedor externo
  metadatos       Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          tenants  @relation(fields: [tenantId], references: [id])
}
