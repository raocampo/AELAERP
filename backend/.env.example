# ====================================
# AELA ERP — Variables de entorno
# Copiar a .env y completar valores
# ====================================

# ── Base de datos PostgreSQL ─────────────────────────────────────────────────
# BD del tenant activo (modo mono) o BD específica del tenant resuelto (modo multi)
DATABASE_URL="postgresql://usuario:contraseña@host:5432/scfi_db"

# BD Master — catálogo de tenants SaaS (activa modo multi-tenant)
DATABASE_MASTER_URL="postgresql://usuario:contraseña@host:5432/scfi_master"

# BD Admin — necesaria para CREATE DATABASE en provisioning (puede ser la misma que master)
DATABASE_ADMIN_URL="postgresql://usuario:contraseña@host:5432/postgres"

# ── Configuración de BD para nuevos tenants ──────────────────────────────────
DB_TENANT_HOST=localhost
DB_TENANT_PORT=5432
DB_TENANT_USER=postgres

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="CAMBIAR_POR_SECRETO_LARGO_ALEATORIO_MINIMO_32_CHARS"
JWT_EXPIRES_IN="30d"

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=5600
NODE_ENV=development

# ── Edición del sistema ───────────────────────────────────────────────────────
# full = todas las funciones | lite = máx 100 comprobantes/año
SCFI_EDITION=full

# ── Modo empresa ─────────────────────────────────────────────────────────────
# mono = una empresa fija | multi = SaaS multi-tenant
MODO_EMPRESA=mono

# Dominio base para URLs de acceso de tenants (ej: app.aela.ec)
SCFI_DOMINIO_BASE=app.aela.ec

# Slug fijo del tenant en modo mono (solo si MODO_EMPRESA=mono)
# SCFI_TENANT_SLUG=mi-empresa

# ── SMTP — Email de bienvenida y notificaciones ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@corpsimtelec.com
SMTP_PASS=
SMTP_FROM="AELA ERP <info@corpsimtelec.com>"
# Email destino para alertas internas de soporte
SMTP_SOPORTE=info@corpsimtelec.com

# ── CORS — URL del frontend ───────────────────────────────────────────────────
# En producción: URL de Vercel o dominio personalizado
FRONTEND_URL=http://localhost:5174

